#!/usr/bin/env bash
set -euo pipefail

PROGRAM="solang-stellar"

usage() {
  cat <<'USAGE'
solang-stellar test [options]

Goal:
  Compile a Solidity contract with Solang, deploy it to Soroban, then invoke a function.

Examples:
  solang-stellar test --file arr_arg_c.sol --function arr_arg --arr "[1,2]"
  solang-stellar test --function arr_arg --arr "[1,2]"

Options:
  --file <path>               Solidity source file (default: inferred if only one *.sol in cwd)
  --function <name>           Function to invoke (required)
  --contract <name>           Forward to `solang compile --contract`
  --output <dir>              Forward to `solang compile --output`
  --emit <kind>               Forward to `solang compile --emit`
  --strict-soroban-types      Forward to `solang compile --strict-soroban-types`
  -O <level>                  Forward to `solang compile -O <none|less|default|aggressive>`
  --wasm-opt <level>          Forward to `solang compile --wasm-opt`
  --release                   Forward to `solang compile --release`
  --solang-target <name>      Forward to `solang compile --target <name>` (default: soroban)
  --wasm <path>               Override inferred wasm path for deploy
  --network <name>            Stellar network profile (default: testnet)
  --arg <name=value>          Function argument (repeatable)
  --<argname> <value>         Function argument passthrough (repeatable)
  --send <default|no|yes>     Forward to `stellar contract invoke --send`
  --verbose                   Print exact commands before execution
  --help                      Show this help

Notes:
  - Array args should be quoted to avoid shell globbing, e.g. --arr "[1,2]"
  - If multiple .sol files exist, use --file
  - Warning: generate a Stellar key before using this tool
  - If STELLAR_ACCOUNT is set, it will be used; otherwise the Stellar CLI default key is used
USAGE
}

err() {
  printf "%s: %s\n" "$PROGRAM" "$*" >&2
}

note() {
  printf "%s: %s\n" "$PROGRAM" "$*" >&2
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    err "Missing required command: $1"
    exit 127
  }
}

print_cmd() {
  printf ">>"
  for arg in "$@"; do
    printf " %q" "$arg"
  done
  printf "\n"
}

pretty_block() {
  local title="$1"
  local content="$2"
  printf "\n%s\n" "$title"
  printf "%s\n" "----------------------------------------"
  printf "%s\n" "$content"
}

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf "%s" "$s"
}

detect_default_key() {
  local keys_out=""
  local line=""
  local name=""
  local count=0
  local only=""
  local cmd=""

  for cmd in list ls; do
    keys_out="$(stellar keys "$cmd" 2>/dev/null || true)"
    [[ -n "$keys_out" ]] && break
  done

  while IFS= read -r line; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    if [[ "$line" =~ ^[[:space:]]*No[[:space:]]+keys ]]; then
      continue
    fi
    if [[ "$line" =~ ^(NAME|Name|Keys|Key)[[:space:]]*$ ]]; then
      continue
    fi
    if [[ "$line" =~ ^-+$ ]]; then
      continue
    fi
    if [[ "$line" =~ ^[[:space:]]*\* ]]; then
      line="${line#\*}"
      line="${line#"${line%%[![:space:]]*}"}"
      name="${line%%[[:space:]]*}"
      [[ -n "$name" ]] && { printf "%s\n" "$name"; return 0; }
    fi
    if [[ "$line" == *"(default)"* ]]; then
      line="${line//(default)/}"
      line="${line#"${line%%[![:space:]]*}"}"
      name="${line%%[[:space:]]*}"
      [[ -n "$name" ]] && { printf "%s\n" "$name"; return 0; }
    fi
    if [[ "$line" =~ default[[:space:]]*:[[:space:]]* ]]; then
      name="${line#*default:}"
      name="${name#"${name%%[![:space:]]*}"}"
      name="${name%%[[:space:]]*}"
      [[ -n "$name" ]] && { printf "%s\n" "$name"; return 0; }
    fi
    if [[ ! "$line" =~ ^[[:space:]]*\*?[A-Za-z0-9._-]+ ]]; then
      continue
    fi
    count=$((count+1))
    only="$line"
  done <<< "$keys_out"

  if (( count == 1 )); then
    name="${only%%[[:space:]]*}"
    [[ -n "$name" ]] && { printf "%s\n" "$name"; return 0; }
  fi

  return 1
}

subcmd="${1:-}"
if [[ -z "$subcmd" || "$subcmd" == "-h" || "$subcmd" == "--help" ]]; then
  usage
  exit 0
fi
if [[ "$subcmd" != "test" ]]; then
  err "Unknown subcommand: $subcmd"
  usage
  exit 2
fi
shift

file=""
function_name=""
network="testnet"
source_account=""
wasm_path=""
output_dir=""
verbose=0
solang_target_set=0

compile_args=()
invoke_args=()
invoke_opts=()
arg_kv=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --file)
      file="$2"
      shift 2
      ;;
    --function)
      function_name="$2"
      shift 2
      ;;
    --network)
      network="$2"
      shift 2
      ;;
    --wasm)
      wasm_path="$2"
      shift 2
      ;;
    --output)
      output_dir="$2"
      compile_args+=("--output" "$2")
      shift 2
      ;;
    --contract)
      compile_args+=("--contract" "$2")
      shift 2
      ;;
    --emit)
      compile_args+=("--emit" "$2")
      shift 2
      ;;
    --strict-soroban-types)
      compile_args+=("--strict-soroban-types")
      shift
      ;;
    -O)
      compile_args+=("-O" "$2")
      shift 2
      ;;
    --wasm-opt)
      compile_args+=("--wasm-opt" "$2")
      shift 2
      ;;
    --release)
      compile_args+=("--release")
      shift
      ;;
    --solang-target)
      compile_args+=("--target" "$2")
      solang_target_set=1
      shift 2
      ;;
    --arg)
      arg_kv+=("$2")
      shift 2
      ;;
    --send)
      invoke_opts+=("--send" "$2")
      shift 2
      ;;
    --verbose)
      verbose=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    -[a-zA-Z])
      if [[ $# -lt 2 ]]; then
        err "Missing value for $1"
        exit 2
      fi
      short_name="${1#-}"
      invoke_args+=("--$short_name" "$2")
      shift 2
      ;;
    --)
      shift
      break
      ;;
    --*)
      if [[ $# -lt 2 ]]; then
        err "Missing value for $1"
        exit 2
      fi
      arg_name="${1#--}"
      invoke_args+=("--$arg_name" "$2")
      shift 2
      ;;
    *)
      err "Unexpected argument: $1"
      exit 2
      ;;
  esac
done

if [[ -z "$file" ]]; then
  shopt -s nullglob
  sol_files=( *.sol )
  shopt -u nullglob
  if (( ${#sol_files[@]} == 0 )); then
    err "No .sol files found. Use --file."
    exit 2
  fi
  if (( ${#sol_files[@]} > 1 )); then
    err "Multiple .sol files found. Use --file."
    exit 2
  fi
  file="${sol_files[0]}"
fi

if [[ ! -f "$file" ]]; then
  err "File not found: $file"
  exit 2
fi

if [[ -z "$function_name" ]]; then
  err "--function is required"
  exit 2
fi

source_account="${STELLAR_ACCOUNT:-}"
if [[ -z "$source_account" ]]; then
  source_account="$(detect_default_key || true)"
  if [[ -n "$source_account" ]]; then
    note "STELLAR_ACCOUNT not set. Using Stellar CLI default key: $source_account"
  else
    err "No Stellar key found. Generate one or set STELLAR_ACCOUNT."
    exit 2
  fi
fi

if (( ${#arg_kv[@]} > 0 )); then
  for kv in "${arg_kv[@]}"; do
    if [[ "$kv" != *"="* ]]; then
      err "--arg expects name=value (got '$kv')"
      exit 2
    fi
    name="${kv%%=*}"
    value="${kv#*=}"
    if [[ -z "$name" ]]; then
      err "--arg expects name=value (got '$kv')"
      exit 2
    fi
    invoke_args+=("--$name" "$value")
  done
fi

need_cmd "solang"
need_cmd "stellar"

if [[ -z "$output_dir" ]]; then
  output_dir=".solang-stellar-test/out"
  compile_args+=("--output" "$output_dir")
fi
mkdir -p "$output_dir"

if (( solang_target_set == 0 )); then
  if [[ -n "${SOLANG_TARGET:-}" ]]; then
    compile_args+=("--target" "${SOLANG_TARGET}")
  else
    compile_args+=("--target" "soroban")
  fi
fi

network_args=()
if [[ -n "$network" ]]; then
  network_args+=("--network" "$network")
fi

compile_cmd=(solang compile "$file" "${compile_args[@]}")
if (( verbose )); then
  print_cmd "${compile_cmd[@]}"
fi
printf "[1/3] Compile: "
if "${compile_cmd[@]}"; then
  printf "OK\n"
else
  printf "FAIL\n"
  exit 1
fi

if [[ -z "$wasm_path" ]]; then
  base_name="$(basename "$file" .sol)"
  candidate="$output_dir/$base_name.wasm"
  if [[ -f "$candidate" ]]; then
    wasm_path="$candidate"
  else
    shopt -s nullglob
    wasm_candidates=("$output_dir"/*.wasm)
    shopt -u nullglob
    if (( ${#wasm_candidates[@]} == 0 )); then
      err "No .wasm found in $output_dir. Use --wasm or --output."
      exit 2
    fi
    if (( ${#wasm_candidates[@]} > 1 )); then
      err "Multiple .wasm files found in $output_dir. Use --wasm or --contract."
      exit 2
    fi
    wasm_path="${wasm_candidates[0]}"
  fi
fi

if [[ ! -f "$wasm_path" ]]; then
  err "WASM not found: $wasm_path"
  exit 2
fi

deploy_cmd=(stellar contract deploy)
if [[ -n "$source_account" ]]; then
  deploy_cmd+=(--source-account "$source_account")
fi
deploy_cmd+=("${network_args[@]}" --wasm "$wasm_path")
if (( verbose )); then
  print_cmd "${deploy_cmd[@]}"
fi
printf "[2/3] Deploy: "
if deploy_out=$("${deploy_cmd[@]}" 2>&1); then
  contract_id=$(printf "%s\n" "$deploy_out" | grep -Eo 'C[A-Z0-9]{55,}' | head -n1 || true)
  if [[ -z "$contract_id" ]]; then
    printf "FAIL\n"
    err "Could not parse contract ID from deploy output"
    printf "%s\n" "$deploy_out" >&2
    exit 1
  fi
  printf "OK (ID=%s)\n" "$contract_id"
else
  printf "FAIL\n"
  printf "%s\n" "$deploy_out" >&2
  exit 1
fi

invoke_cmd=(stellar contract invoke --id "$contract_id")
if [[ -n "$source_account" ]]; then
  invoke_cmd+=(--source-account "$source_account")
fi
if (( ${#network_args[@]} > 0 )); then
  invoke_cmd+=("${network_args[@]}")
fi
if (( ${#invoke_opts[@]} > 0 )); then
  invoke_cmd+=("${invoke_opts[@]}")
fi
invoke_cmd+=(-- "$function_name")
if (( ${#invoke_args[@]} > 0 )); then
  invoke_cmd+=("${invoke_args[@]}")
fi
if (( verbose )); then
  print_cmd "${invoke_cmd[@]}"
fi
printf "[3/3] Invoke: "
if invoke_out=$("${invoke_cmd[@]}" 2>&1); then
  printf "OK\n"
else
  printf "FAIL\n"
  printf "%s\n" "$invoke_out" >&2
  exit 1
fi

printf "\ncontract_id=%s\n" "$contract_id"
printf "function=%s\n" "$function_name"
if (( ${#invoke_args[@]} > 0 )); then
  # Print args in a readable, flat format
  args_line=""
  i=0
  while (( i < ${#invoke_args[@]} )); do
    key="${invoke_args[$i]}"; val="${invoke_args[$((i+1))]}"
    if [[ -n "$args_line" ]]; then
      args_line+=", "
    fi
    args_line+="${key#--}:$val"
    i=$((i+2))
  done
  printf "args=%s\n" "$args_line"
fi
printf "result=%s\n" "$invoke_out"

result_value="$invoke_out"
invoke_notice=""
if [[ "$invoke_out" == *$'\n'* ]]; then
  first_line="${invoke_out%%$'\n'*}"
  rest="${invoke_out#*$'\n'}"
  if [[ "$first_line" == "ℹ️ "* || "$first_line" == "info:"* || "$first_line" == "INFO:"* ]]; then
    invoke_notice="$first_line"
    result_value="$rest"
  fi
fi
result_value="$(printf "%s" "$result_value" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

json_contract_id="$(json_escape "$contract_id")"
json_function="$(json_escape "$function_name")"
json_result="$(json_escape "$result_value")"
json_args=""
json_notice=""
if [[ -n "$args_line" ]]; then
  json_args=",\"args\":\"$(json_escape "$args_line")\""
fi
if [[ -n "$invoke_notice" ]]; then
  json_notice=",\"notice\":\"$(json_escape "$invoke_notice")\""
fi
printf "SOLANG_STELLAR_RESULT='%s'\n" "{\"contract_id\":\"$json_contract_id\",\"function\":\"$json_function\",\"result\":\"$json_result\"$json_args$json_notice}"

if (( verbose )); then
  pretty_block "Deploy output:" "$deploy_out"
  pretty_block "Invoke output:" "$invoke_out"
fi
